# Non-sensitive application configuration.
#
# This whole file maps cleanly to a Kubernetes ConfigMap during the
# training capstone. It is safe to commit to git.

APP_NAME=starter-app
APP_VERSION=1.0.0
GREETING=Hello, world!

# Port the app listens on inside the container.
PORT=8080

# Connection to the Redis backing service.
# REDIS_HOST is the Compose service name today; in Kubernetes it becomes
# the (headless) Service name that fronts the Redis StatefulSet.
REDIS_HOST=redis
REDIS_PORT=6379
